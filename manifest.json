{
  "manifest_version": 3,
  "name": "GitHub Profile Insights",
  "version": "1.0.0",
  "description": "Adds contribution insights dashboard to any GitHub profile - streaks, language breakdown, PR stats, and activity heatmap.",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://github.com/*"
      ],
      "css": [
        "css/insights.css"
      ],
      "js": [
        "js/utils.js",
        "js/auth.js",
        "js/api.js",
        "js/charts.js",
        "js/dashboard.js",
        "js/main.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://gpi-auth.sg85207.workers.dev/*"
      ],
      "js": [
        "js/auth-callback.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
